# ===========================================
# ScamShield Backend — Environment Variables
# Copy this file to .env and fill in real values.
# Do NOT commit .env to version control.
# ===========================================

# Application
NODE_ENV=development
PORT=5000
API_VERSION=v1

# MongoDB
MONGODB_URI=mongodb://localhost:27017/scamshield

# CORS
# Comma-separated list of allowed origins (no spaces), e.g.:
# CORS_ALLOWED_ORIGINS=https://scamshield.app,https://admin.scamshield.app
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Logging
# One of: fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=info

# JWT Secrets (minimum 32 characters each)
JWT_ACCESS_SECRET=change_this_to_a_random_32plus_char_secret
